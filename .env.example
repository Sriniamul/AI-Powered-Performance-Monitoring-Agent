# Set DRY_RUN=true for local demo without calling JIRA.
DRY_RUN=true

# JIRA Cloud settings. Required only when DRY_RUN=false.
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=replace_me
JIRA_PROJECT_KEY=PERF
JIRA_ISSUE_TYPE=Bug

# Optional notification placeholder.
NOTIFICATION_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
LLM_PROVIDER=openai
COPILOT_KEY=
COPILOT_MODEL=gpt-5
